rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Qualquer pessoa pode ler (ver presentes e convidados)
    // Qualquer pessoa pode escrever (confirmar presença, escolher presente)
    // Isso é intencional para um site de festa simples sem backend
    match /luisa_db/{document} {
      allow read, write: if true;
    }
  }
}
